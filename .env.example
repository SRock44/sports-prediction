# Copy to .env and fill in secrets. Never commit .env.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=prediction
POSTGRES_USER=prediction_app
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_MIGRATION_USER=prediction_migration
POSTGRES_MIGRATION_PASSWORD=changeme_migration_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_use_32_random_bytes_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
# Comma-separated allowed origins for CORS (empty = deny all)
ALLOWED_ORIGINS=
# Comma-separated IPs allowed to hit admin endpoints
ADMIN_IP_ALLOWLIST=127.0.0.1

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=prediction

# ── Discord bot ───────────────────────────────────────────────────────────────
# Bot token: discord.com/developers/applications → your app → Bot → Reset Token
# DISCORD_BOT_TOKEN=
# Server ID: Enable Developer Mode → right-click your server → Copy Server ID
# DISCORD_GUILD_ID=

# ── Discord webhooks (proactive posts — Celery, no bot required) ──────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
# DISCORD_WEBHOOK_NBA=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_MLB=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_OPS=https://discord.com/api/webhooks/...

# ── Telegram ──────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID_NBA=
# TELEGRAM_CHAT_ID_MLB=

# ── Backfill ──────────────────────────────────────────────────────────────────
NBA_BACKFILL_SEASONS=5
MLB_BACKFILL_SEASONS=5

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
