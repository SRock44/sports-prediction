# Replace example.com with your actual domain.
# For local dev, use http://localhost and remove tls directives.

example.com {
    tls {
        protocols tls1.3
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        # Swagger UI (/docs, /redoc) requires inline scripts/styles and CDN assets.
        # Tighten or remove the script/style exceptions once docs are disabled in prod.
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' cdn.jsdelivr.net; connect-src 'self'"
        -Server
    }

    # Forward all traffic to the FastAPI container
    reverse_proxy api:8000 {
        health_uri /v1/health
        health_interval 30s
    }

    # HTTP → HTTPS redirect is automatic with Caddy
    log {
        output stdout
        format json
    }
}
